# Copy to .env and adjust for your machine
# Vite only exposes variables prefixed with VITE_

# API base URL (must include /api/v1)
VITE_API_BASE_URL=/api/v1

# Backend origin for Vite dev proxy (no trailing slash)
VITE_API_PROXY_TARGET=http://localhost:3000

# Dev server port (optional)
VITE_DEV_SERVER_PORT=5173

# Google OAuth Web Client ID — same as GOOGLE_CLIENT_ID in Backend/.env
# Must be OAuth client type "Web application" (not Desktop/Android).
# Google Cloud Console → Credentials → your Web client → Authorized JavaScript origins:
#   http://localhost:5173
#   http://127.0.0.1:5173
# (Add the exact origin shown in the browser address bar — localhost ≠ 127.0.0.1)
VITE_GOOGLE_CLIENT_ID=
